# Generate a strong JWT secret with: openssl rand -hex 32
JWT_SECRET=

# Database password — set this to something strong
DB_PASSWORD=

# TMDB API Read Access Token — get from https://www.themoviedb.org/settings/api
VITE_TMDB_TOKEN=

# Path on your host machine where media is stored
MEDIA_PATH=/mnt/media

# Timezone — e.g. America/Chicago, America/New_York, Europe/London
TZ=America/Chicago

# Jellyfin — set after first boot
JELLYFIN_URL=http://jellyfin:8096
JELLYFIN_API_KEY=

# Radarr — set after first boot
RADARR_API_KEY=

# Sonarr — set after first boot
SONARR_API_KEY=

# Prowlarr — set after first boot
PROWLARR_API_KEY=
